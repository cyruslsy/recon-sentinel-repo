# ═══════════════════════════════════════════════════════════════
# Recon Sentinel — Environment Configuration
# Copy to .env and fill in values. NEVER commit .env to git.
# Secrets should use Docker secrets (see docs/), not env vars.
# ═══════════════════════════════════════════════════════════════

# ─── Database ─────────────────────────────────────────────────
POSTGRES_DB=recon_sentinel
POSTGRES_USER=sentinel
# POSTGRES_PASSWORD → Use Docker secret: secrets/db_password
DATABASE_URL=postgresql+asyncpg://sentinel:@localhost:5432/recon_sentinel

# ─── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ─── JWT ──────────────────────────────────────────────────────
# JWT_SECRET_KEY → Use Docker secret: secrets/jwt_secret.key
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
JWT_ALGORITHM=HS256

# ─── LLM ──────────────────────────────────────────────────────
# ANTHROPIC_API_KEY → Use Docker secret: secrets/anthropic_api_key
LLM_DEFAULT_MODEL=claude-haiku-4.5
LLM_ANALYSIS_MODEL=claude-sonnet-4.6
LLM_FALLBACK_MODEL=ollama/qwen2.5:7b
LLM_FALLBACK_TIMEOUT_SECONDS=15
LLM_MONTHLY_BUDGET_USD=50.00
LLM_MAX_REPLAN_COST_USD=0.50
LLM_MAX_REPLAN_ITERATIONS=3

# ─── Ollama (local LLM) ──────────────────────────────────────
OLLAMA_BASE_URL=http://ollama:11434

# ─── External API Keys (use Docker secrets in production) ─────
# SHODAN_API_KEY=
# VIRUSTOTAL_API_KEY=
# GREYNOISE_API_KEY=
# DEHASHED_API_KEY=
# LEAKCHECK_API_KEY=
# HIBP_API_KEY=

# ─── Application ──────────────────────────────────────────────
APP_ENV=development
APP_DEBUG=true
API_HOST=0.0.0.0
API_PORT=8000
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ─── Celery ───────────────────────────────────────────────────
CELERY_WORKER_CONCURRENCY=4
CELERY_BROWSER_WORKER_CONCURRENCY=2

# ─── Scan Defaults ────────────────────────────────────────────
SCAN_DEFAULT_RATE_LIMIT=100
SCAN_DEFAULT_STEALTH_LEVEL=3
SCAN_MAX_CONCURRENT=3

# ─── Data Retention ──────────────────────────────────────────
DATA_RETENTION_DAYS=90
SCREENSHOT_STORAGE_PATH=/data/screenshots
REPORT_STORAGE_PATH=/data/reports
