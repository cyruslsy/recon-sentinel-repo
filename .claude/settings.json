{
  "permissions": {
    "allow": [
      "Bash(docker compose *)",
      "Bash(git *)",
      "Bash(python -m pytest *)",
      "Bash(cat *)",
      "Bash(grep *)",
      "Bash(find *)",
      "Bash(wc *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(ls *)",
      "Bash(curl *)",
      "Bash(pip install *)",
      "Bash(npm *)",
      "Bash(alembic *)",
      "Bash(cd *)",
      "Bash(mkdir *)",
      "Bash(cp *)",
      "Bash(mv *)",
      "Edit(backend/**)",
      "Edit(frontend/**)",
      "Edit(tests/**)",
      "Edit(docs/**)",
      "Edit(CLAUDE.md)",
      "Edit(REVIEW.md)",
      "Edit(.claude/**)",
      "Edit(docker-compose*)",
      "Write(backend/**)",
      "Write(frontend/**)",
      "Write(tests/**)",
      "Write(docs/**)"
    ],
    "deny": [
      "Edit(secrets/**)",
      "Edit(.env)",
      "Write(secrets/**)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'INPUT=$(cat); FILE=$(echo \"$INPUT\" | jq -r \".tool_input.file_path // empty\"); if [[ \"$FILE\" == *.py ]]; then python3 -m py_compile \"$FILE\" 2>&1 || true; fi'",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
