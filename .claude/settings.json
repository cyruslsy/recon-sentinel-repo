{
  "permissions": {
    "allow": [
      "Bash(docker compose *)",
      "Bash(git *)",
      "Bash(python -m pytest *)",
      "Bash(cat *)",
      "Bash(grep *)",
      "Bash(find *)",
      "Bash(wc *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(ls *)",
      "Bash(curl *)",
      "Bash(pip install *)",
      "Bash(npm *)",
      "Bash(alembic *)",
      "Edit(backend/**)",
      "Edit(frontend/**)",
      "Edit(tests/**)",
      "Edit(docs/**)",
      "Edit(CLAUDE.md)",
      "Edit(REVIEW.md)",
      "Edit(.claude/**)",
      "Edit(docker-compose*)",
      "Edit(Dockerfile)"
    ],
    "deny": [
      "Edit(secrets/**)",
      "Edit(.env)",
      "Bash(rm -rf /)"
    ]
  },
  "hooks": {
    "afterEdit": [
      {
        "pattern": "backend/**/*.py",
        "command": "cd backend && python -m py_compile ${file} 2>&1 || true"
      }
    ],
    "preCommit": [
      {
        "command": "cd backend && python -m pytest tests/ -x -q --tb=line 2>&1 | tail -5"
      }
    ]
  }
}
